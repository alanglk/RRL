@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Search for dependencies only if RRL is built as a static library
if(NOT @RRL_SHARED@)

    # User is expected to provide EnTT, GLM and GLFW3
    find_dependency(EnTT) 
    find_dependency(glm)
    if(@RRL_BUILD_WINDOW_GLFW@)
        find_dependency(glfw3)
    endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/RRLTargets.cmake")

check_required_components(RRL)