@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# GLM, EnTT and FLogging are required as a PUBLIC dependencies
find_dependency(FLogging @PROJECT_VERSION@ EXACT)
find_dependency(EnTT 3.16.0 EXACT)
find_dependency(glm 1.0.3)

# GLFW is hidden inside RRL's .so file. The user only needs to find it
# if they are linking against RRL as a STATIC library.
if(NOT @RRL_SHARED@)
    if(@RRL_BUILD_WINDOW_GLFW@)
        find_dependency(glfw3)
    endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/RRLTargets.cmake")

check_required_components(RRL)
